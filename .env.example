# 天地图智能开发平台 - 环境配置

# 服务器
PORT=3000
NODE_ENV=development

# 天地图 API Token
TIANDITU_TOKEN=your_tianditu_token_here

# LLM API（OpenAI 兼容）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://aihubmix.com/v1
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-5

# 文件上传
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# 日志
LOG_LEVEL=debug
