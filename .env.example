# 天地图智能开发平台 - 环境配置

# 服务器
PORT=3000
NODE_ENV=development

# 天地图 API Token
TIANDITU_TOKEN=your_tianditu_token_here

# Qwen3.5 Plus（阿里云百炼 OpenAI 兼容 + Responses API）
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_RESPONSES_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
LLM_MODEL=qwen3.5-plus
VISUAL_INSPECTION_MODEL=qwen3.5-flash
# 非代码生成类辅助判断默认走轻量模型；native_tool_loop 的辅助判断也会复用它
AUX_LLM_MODEL=qwen3-coder-next
# 兼容保留：如需单独覆盖 native_tool_loop 的辅助模型，可显式设置
NATIVE_TOOL_LOOP_AUX_MODEL=qwen3-coder-next

# 文件上传
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
SHARE_DIR=./share
RUN_DOSSIER_ENABLED=true
RUN_DOSSIER_DIR=./run-dossiers
SHARE_THUMBNAIL_ENABLED=true
# 内部截图时访问分享页面的服务基址（默认 http://127.0.0.1:$PORT）
SHARE_THUMBNAIL_BASE_URL=http://127.0.0.1:3000
# 可选：Chromium 可执行文件路径（容器内推荐 /usr/bin/chromium）
THUMBNAIL_CHROMIUM_PATH=
# 缩略图截图超时与额外等待（毫秒）
SHARE_THUMBNAIL_TIMEOUT_MS=12000
SHARE_THUMBNAIL_WAIT_MS=600
VISUAL_INSPECTION_LLM_TIMEOUT_MS=45000

# 行政区划编码对照表（xlsx，可选）
# 默认会尝试读取 server/assets/admin/xzqh2020-03.xlsx
ADMIN_CODEBOOK_XLSX_PATH=

# 日志
LOG_LEVEL=debug

# Agent 运行模式
AGENT_RUNTIME_MODE=agent_first_full
AGENT_ENABLE_VERIFIER=true

# Agent 工具能力
AGENT_TOOLS_ENABLED=true
# 默认使用项目根目录；如需限制范围可显式指定
AGENT_WORKSPACE_ROOT=
AGENT_TOOL_MAX_STEPS=3

# 兼容保留：本地 web_search fallback（Responses 原生搜索默认不会用到）
AGENT_WEB_SEARCH_PROVIDER=duckduckgo
AGENT_WEB_SEARCH_MAX_RESULTS=5
AGENT_WEB_SEARCH_TIMEOUT_MS=15000
SERPER_API_KEY=

# web_fetch
AGENT_FETCH_TIMEOUT_MS=15000
AGENT_FETCH_MAX_BYTES=524288

# snippet_edit
AGENT_EDIT_CONTEXT_LINES=2
AGENT_EDIT_MAX_SNIPPET_CHARS=2400

# 统一登录开关（默认关闭；打开后工作台与运行档案要求登录）
AUTH_ENABLED=false
AUTH_COOKIE_NAME=tdt_auth
AUTH_SHARED_SECRET=change-this-in-production
AUTH_LOGIN_PATH=/sso/login
AUTH_LOGOUT_PATH=/sso/logout
AUTH_TRUST_PROXY=true

# auth-bridge（开发桥服务）
AUTH_BRIDGE_PORT=8080
AUTH_COOKIE_MAX_AGE_SECONDS=7200
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_BRIDGE_MODE=mock
AUTH_BRIDGE_SDK_JAR=
AUTH_BRIDGE_SDK_EXTRA_CLASSPATH=
AUTH_BRIDGE_ACCESS_KEY=
AUTH_BRIDGE_SECRET_KEY=
AUTH_BRIDGE_SDK_AUTO_DETECT_LOCAL_DEPS=true
AUTH_BRIDGE_MOCK_SUB=tdt-dev-user
AUTH_BRIDGE_MOCK_LOGIN_NAME=tdt.dev
AUTH_BRIDGE_MOCK_DISPLAY_NAME=天地图开发用户
AUTH_BRIDGE_MOCK_EMAIL=
AUTH_BRIDGE_MOCK_GBCODE=
AUTH_BRIDGE_MOCK_COMPANY_NAME=
AUTH_BRIDGE_MOCK_USER_TYPE=2

# auth-bridge-official（Spring Boot 2 正式桥）
AUTH_BRIDGE_OFFICIAL_PORT=8081
AUTH_BRIDGE_PUBLIC_BASE_URL=http://localhost:8081
AUTH_BRIDGE_CAS_SERVER_URL_PREFIX=https://oauth.tianditu.gov.cn
AUTH_BRIDGE_CAS_SERVER_LOGIN_URL=https://oauth.tianditu.gov.cn/login
AUTH_BRIDGE_CAS_LOGOUT_URL=
AUTH_BRIDGE_CLIENT_CLUSTERS=http://localhost:8081
AUTH_BRIDGE_USS_URL=https://uss.tianditu.cn
AUTH_BRIDGE_SKIP_CHECK_KEY=
AUTH_BRIDGE_ENCODE_DATA=0
AUTH_BRIDGE_REDIRECT_AFTER_VALIDATION=true
AUTH_BRIDGE_USER_SESSION=true
AUTH_BRIDGE_DEFAULT_REDIRECT=/workspace
AUTH_BRIDGE_LOGOUT_REDIRECT=/
AUTH_BRIDGE_USER_INFO_LOOKUP_ENABLED=true
