# 天地图智能开发平台 - 环境配置

# 服务器
PORT=3000
NODE_ENV=development

# 天地图 API Token
TIANDITU_TOKEN=your_tianditu_token_here

# Qwen3.5 Plus（阿里云百炼 OpenAI 兼容 + Responses API）
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_RESPONSES_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
LLM_MODEL=qwen3.5-plus

# 文件上传
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
SHARE_DIR=./share
RUN_DOSSIER_ENABLED=true
RUN_DOSSIER_DIR=./run-dossiers
SHARE_THUMBNAIL_ENABLED=true
# 内部截图时访问分享页面的服务基址（默认 http://127.0.0.1:$PORT）
SHARE_THUMBNAIL_BASE_URL=http://127.0.0.1:3000
# 可选：Chromium 可执行文件路径（容器内推荐 /usr/bin/chromium）
THUMBNAIL_CHROMIUM_PATH=
# 缩略图截图超时与额外等待（毫秒）
SHARE_THUMBNAIL_TIMEOUT_MS=12000
SHARE_THUMBNAIL_WAIT_MS=600
VISUAL_INSPECTION_LLM_TIMEOUT_MS=45000

# 行政区划编码对照表（xlsx，可选）
# 默认会尝试读取 server/assets/admin/xzqh2020-03.xlsx
ADMIN_CODEBOOK_XLSX_PATH=

# 日志
LOG_LEVEL=debug

# Agent 运行模式
AGENT_RUNTIME_MODE=agent_first_full
AGENT_ENABLE_VERIFIER=true

# Agent 工具能力
AGENT_TOOLS_ENABLED=true
# 默认使用项目根目录；如需限制范围可显式指定
AGENT_WORKSPACE_ROOT=
AGENT_TOOL_MAX_STEPS=3

# 兼容保留：本地 web_search fallback（Responses 原生搜索默认不会用到）
AGENT_WEB_SEARCH_PROVIDER=duckduckgo
AGENT_WEB_SEARCH_MAX_RESULTS=5
AGENT_WEB_SEARCH_TIMEOUT_MS=15000
SERPER_API_KEY=

# web_fetch
AGENT_FETCH_TIMEOUT_MS=15000
AGENT_FETCH_MAX_BYTES=524288

# snippet_edit
AGENT_EDIT_CONTEXT_LINES=2
AGENT_EDIT_MAX_SNIPPET_CHARS=2400
