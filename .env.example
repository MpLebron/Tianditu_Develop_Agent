# 天地图智能开发平台 - 环境配置

# 服务器
PORT=3000
NODE_ENV=development

# 天地图 API Token
TIANDITU_TOKEN=your_tianditu_token_here

# LLM API（OpenAI 兼容）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://aihubmix.com/v1
LLM_PROVIDER=qwen
LLM_MODEL=qwen3.5-plus

# Qwen 专用（阿里云百炼 OpenAI 兼容）
# 当 provider=qwen 时优先使用以下配置；未配置时回退到 LLM_API_KEY / LLM_BASE_URL
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 文件上传
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
SHARE_DIR=./share
SHARE_THUMBNAIL_ENABLED=true
# 内部截图时访问分享页面的服务基址（默认 http://127.0.0.1:$PORT）
SHARE_THUMBNAIL_BASE_URL=http://127.0.0.1:3000
# 可选：Chromium 可执行文件路径（容器内推荐 /usr/bin/chromium）
THUMBNAIL_CHROMIUM_PATH=
# 缩略图截图超时与额外等待（毫秒）
SHARE_THUMBNAIL_TIMEOUT_MS=12000
SHARE_THUMBNAIL_WAIT_MS=600

# 行政区划编码对照表（xlsx，可选）
# 默认会尝试读取 server/assets/admin/xzqh2020-03.xlsx
ADMIN_CODEBOOK_XLSX_PATH=

# 日志
LOG_LEVEL=debug
